<%- include('partials/header', { 
    title: title,
    description: 'Learn about UniSelfie, a local family-run Seattle photo booth company creating unforgettable event memories for the past five years.',
    page: 'about'
}) %>

        <!-- Page Hero -->
        <section class="page-hero">
            <div class="hero-content">
                <h1>About UniSelfie</h1>
                <p>Five years of bringing fun, energy, and unforgettable moments to events across Seattle</p>
            </div>
        </section>

<!-- About Content -->
<section class="section animate-on-scroll">
    <div class="container">
        <div class="two-column">
            <div>
                <h2>Built on Family Values</h2>
                <h3 style="color: #2563eb; margin-bottom: 1rem;">Local, Family-Run, Seattle Proud</h3>
                <p>For the past five years, we've been bringing fun, energy, and unforgettable memories to events across the Seattle area. From weddings and corporate gatherings to birthdays and community celebrations, our photo booth experiences are designed to capture genuine smiles, candid moments, and high-quality keepsakes guests can take home.</p>
                <p>As a local, family-run business, we pride ourselves on reliable service, seamless communication, and modern setups that look as good as the photos they produce.</p>
                <p>Whether your event is intimate or over-the-top, we're here to make sure every moment is captured and every snapshot feels special.</p>
            </div>
            <div>
                <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="UniSelfie team" style="width: 100%; border-radius: 20px;" />
            </div>
        </div>
    </div>
</section>

<!-- Mission Section -->
<section class="section bg-light animate-on-scroll">
    <div class="container">
        <div class="section-title">
            <h2>Our Mission</h2>
            <p>Create a smooth, fun photo experience that helps people connect and remember the moment</p>
        </div>
        <div class="three-column">
            <div class="card">
                <div class="card-icon">
                    <i class="fas fa-heart"></i>
                </div>
                <h3>Passion for Memories</h3>
                <p>We focus on authentic smiles and candid interactions that become meaningful keepsakes for your guests.</p>
            </div>
            <div class="card">
                <div class="card-icon">
                    <i class="fas fa-star"></i>
                </div>
                <h3>Quality Excellence</h3>
                <p>From lighting and camera quality to print output, we keep our standards high so every photo feels special.</p>
            </div>
            <div class="card">
                <div class="card-icon">
                    <i class="fas fa-users"></i>
                </div>
                <h3>Personal Touch</h3>
                <p>Every event has its own personality. We tailor the experience so your booth feels like it belongs at your celebration.</p>
            </div>
        </div>
    </div>
</section>

<!-- Story Section -->
<section class="section animate-on-scroll">
    <div class="container">
        <div class="two-column">
            <div>
                <img src="https://images.unsplash.com/photo-1511795409834-ef04bbd61622?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Professional photobooth equipment" style="width: 100%; border-radius: 20px;" />
            </div>
            <div>
                <h2>Our Story</h2>
                <p>UniSelfie started with one goal: make event photo experiences feel easier, better, and more memorable for everyone involved.</p>
                <p>Over the years, we've refined every part of our setup to keep things modern, clean, and guest-friendly:</p>
                <ul style="margin: 1rem 0; padding-left: 2rem;">
                    <li>Fast setup and smooth flow during your event</li>
                    <li>High-quality photos and print output</li>
                    <li>Modern booth styling and backdrop options</li>
                    <li>Friendly support your guests can count on</li>
                    <li>Simple communication from first message to event day</li>
                </ul>
                <p>From intimate gatherings to larger celebrations, we bring the same energy, professionalism, and care to every booking.</p>
            </div>
        </div>
    </div>
</section>

