        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
            <a href="/contact" class="btn-primary">Get a Quote</a>
            <a href="/gallery" class="btn-secondary">View Our Work</a>
        </div>
    </div>
